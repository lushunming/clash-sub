## ---------------- 全局配置 ----------------
log-level: info
port: 7890
socks-port: 7891
#redir-port: 7892
tproxy-port: 7894
mixed-port: 7893
ipv6: true
allow-lan: false
unified-delay: true
tcp-concurrent: true # 尝试与多个IP建立TCP连接
external-controller: 127.0.0.1:9090 # 外部UI控制器的访问地址和端口，'0.0.0.0'表示任何IP都可访问
secret: "12345678"
find-process-mode: strict
profile:
  store-selected: true
  store-fake-ip: true
experimental:
  quic-go-disable-gso: false
  quic-go-disable-ecn: false
  dialer-ip4p-convert: false

# ==========================================================
## ---------------- 流量嗅探 ----------------
sniffer:
  enable: true
  force-dns-mapping: true
  parse-pure-ip: true
  override-destination: false
  sniff:
    HTTP:
      ports: [80, 8080-8880]
      override-destination: true
    TLS:
      ports: [443, 5228-5230]
    QUIC:
      ports: [443, 8443, 5228-5230]
  force-domain:
    - "+.v2ex.com"
  skip-domain:
    - "+.local"
  skip-src-address:
    - 192.168.0.0/16
  skip-dst-address:
    - 192.168.0.0/16

# ==========================================================
## ---------------- TUN ----------------
tun:
  enable: true
  stack: System # 栈类型 (gVisor,System,mixed)
  dns-hijack:
  - "any:53"
  auto-route: true # 自动设置系统路由表
  auto-detect-interface: true # 自动检测出口网络接口
  strict-route: true # 将所有连接路由到 tun 来防止泄漏
  disable-icmp-forwarding: true # 禁用 ICMP 转发，防止环回
  mtu: 4064
  udp-timeout: 300

# ==========================================================
## ---------------- DNS ----------------
dns:
  enable: true
  cache-algorithm: arc
  use-hosts: true
  use-system-hosts: false
  listen: '127.0.0.1:1053' #（仅本机127.0.0.1:1053，网关设置0.0.0.0:1053, :53）
  ipv6: true
  #ipv6-timeout: 300
  prefer-h3: true
  respect-rules: false
  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16
  fake-ip-range6: fdfe:dcba:9876::/64
  fake-ip-filter-mode: rule
  #fake-ip-ttl: 1
  fake-ip-filter:
    - "RULE-SET,private,real-ip"
    - "RULE-SET,connectivity-check,real-ip"
    - "RULE-SET,fakeip_filter,real-ip"
    - "RULE-SET,cn,real-ip"
    - "RULE-SET,geolocation-cn,real-ip"
    - "MATCH,fake-ip"
## ---------------- # DNS锚点 #h3=true ----------------
